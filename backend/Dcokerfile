FROM php:8.2-fpm

# ១. ដំឡើង System Dependencies
RUN apt-get update && apt-get install -y \
    libpq-dev libpng-dev libjpeg-dev libfreetype6-dev zip unzip git curl \
    && docker-php-ext-configure gd --with-freetype --with-jpeg \
    && docker-php-ext-install pdo pdo_pgsql gd \
    && rm -rf /var/lib/apt/lists/*

# ២. ដំឡើង Node.js ជំនាន់ ១៨ LTS
RUN curl -fsSL https://deb.nodesource.com/setup_18.x | bash - && apt-get install -y nodejs
COPY --from=composer:latest /usr/bin/composer /usr/bin/composer

WORKDIR /app
COPY . .

# ៣. ដំឡើង Dependencies
RUN composer install --no-dev --optimize-autoloader --ignore-platform-reqs

# ៤. កំណត់ Permissions
RUN mkdir -p /app/storage/app/public /app/storage/framework/cache /app/storage/framework/sessions /app/storage/framework/views /app/storage/logs \
    && chown -R www-data:www-data /app/storage /app/bootstrap/cache \
    && chmod -R 775 /app/storage /app/bootstrap/cache

EXPOSE 8000

# ៥. CMD ដែលសុវត្ថិភាពបំផុត (គ្មាន migrate:fresh ឬ db:wipe)
CMD php artisan storage:link --force; \
    php artisan migrate --force --no-interaction; \
    php artisan config:cache; \
    php artisan route:cache; \
    php artisan serve --host=0.0.0.0 --port=8000
