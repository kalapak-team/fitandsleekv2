FROM php:8.2-fpm

# ១. ដំឡើង System Dependencies សម្រាប់ PostgreSQL, GD (សម្រាប់រូបភាព) និង Tools ផ្សេងៗ
RUN apt-get update && apt-get install -y \
    libpq-dev \
    libpng-dev \
    libjpeg-dev \
    libfreetype6-dev \
    zip \
    unzip \
    git \
    curl \
    && docker-php-ext-configure gd --with-freetype --with-jpeg \
    && docker-php-ext-install pdo pdo_pgsql gd \
    && rm -rf /var/lib/apt/lists/*

# ២. ដំឡើង Node.js ជំនាន់ ១៨ LTS (សម្រាប់ Compile Assets ឬ Run Node scripts បើមាន)
RUN curl -fsSL https://deb.nodesource.com/setup_18.x | bash - && apt-get install -y nodejs

# ៣. ទាញយក Composer ចុងក្រោយបង្អស់
COPY --from=composer:latest /usr/bin/composer /usr/bin/composer

# ៤. កំណត់ Working Directory ក្នុង Container
WORKDIR /app

# ៥. ចម្លងរាល់ File ទាំងអស់ក្នុង Folder បច្ចុប្បន្នចូលទៅក្នុង /app
COPY . .

# ៦. ដំឡើង PHP Dependencies (Vendor) និង Node Modules (បើមាន Folder node-khqr)
RUN composer install --no-dev --optimize-autoloader --ignore-platform-reqs \
    && if [ -d "node-khqr" ]; then cd node-khqr && npm install --omit=dev && cd ..; fi

# ៧. កំណត់សិទ្ធិ (Permissions) ឱ្យ Laravel អាចសរសេរ File ក្នុង Storage បាន
RUN mkdir -p /app/storage/app/public /app/storage/framework/cache /app/storage/framework/sessions /app/storage/framework/views /app/storage/logs \
    && chown -R www-data:www-data /app/storage /app/bootstrap/cache \
    && chmod -R 775 /app/storage /app/bootstrap/cache

# ៨. បើក Port 8000 សម្រាប់ Railway ចូលមកកាន់ App
EXPOSE 8000


